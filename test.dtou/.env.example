# ============================================
# 南方基金产品布局战略系统 - 环境配置模板
# 请将本文件复制为 .env 并填写实际配置
# ⚠️ 注意：.env 文件包含敏感信息，请勿提交到代码仓库
# ============================================

# ============================================
# Tushare API 配置
# ============================================
# 请从 Tushare 官网 (https://tushare.pro) 获取您的 Token
# 本 Token 仅允许在本项目使用，禁止外传
TUSHARE_TOKEN=隐藏一下

# ============================================
# 数据库配置
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fund_strategy
DB_USERNAME=root
DB_PASSWORD=your_password

# ============================================
# Redis 配置 (可选)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# 服务器配置
# ============================================
SERVER_PORT=8080
